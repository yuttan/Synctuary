<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Network access is the entire point of the app — no point gating it.
        Android Q+ gates "cleartext" traffic; we keep usesCleartextTraffic=false
        as a forcing function: any non-TLS server connection has to be opted
        into per-host via network_security_config.xml at code-review time, not
        as a global flag. PROTOCOL §10 dev-plaintext servers will need that
        explicit opt-in.
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- BiometricPrompt requires this; falls back to PIN/passcode automatically. -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- Foreground service for resumable upload coverage in v0.5+; placeholder. -->
    <!-- <uses-permission android:name="android.permission.FOREGROUND_SERVICE" /> -->

    <application
        android:name=".SynctuaryApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Synctuary"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Synctuary"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
