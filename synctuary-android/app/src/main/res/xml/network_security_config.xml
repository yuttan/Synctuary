<?xml version="1.0" encoding="utf-8"?>
<!--
   RELEASE config: cleartext denied, system CAs only. PROTOCOL §10.1
   dev-plaintext is available only in debug builds via the override at
   src/debug/res/xml/network_security_config.xml.

   User-installed CAs (self-signed home-LAN roots) are trusted only
   in the debug variant to harden release against MITM via a
   sideloaded root cert.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
